{{> _flash}}
<div class="container">
    <h2 class="text-center my-5">Detalles bicicleta id: {{bicicleta.id}}</h2>
    <div class="d-flex justify-content-center">
        <div class="card mb-5 col-3 shadow">
            <div class="card-body text-center">
                <h5 class="card-title mb-3"><strong>Marca: </strong>{{bicicleta.marca}}</h5>
                <p class="card-text"><strong>Modelo: </strong>{{bicicleta.modelo}}</p>
                <p class="card-text"><strong>Tipo: </strong>{{bicicleta.tipo}}</p>
                <p class="card-text"><strong>Precio: </strong>${{bicicleta.precio}}</p>
                <p class="card-text"><strong>Disponible: </strong>{{#if bicicleta.disponible}}Sí{{else}}No{{/if}}</p>
                <p class="card-text"><strong>Año: </strong>{{bicicleta.year}}</p>
                <div class="d-flex gap-2 justify-content-center">
                    <a href="/bicicletas/{{bicicleta.id}}/edit" class="btn btn-warning btn-sm">Editar</a>
                    <form action="/bicicletas/{{bicicleta.id}}?_method=DELETE" method="POST">
                        <button class="btn btn-danger btn-sm" type="submit" onclick="return confirm('Seguro deseas eliminar esta bicicleta?')">Eliminar</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <div class="text-center">
        <a href="/" class="btn btn-dark">Volver al listado</a>
    </div>
</div>